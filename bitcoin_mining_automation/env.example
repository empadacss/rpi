# Configurações do Sistema de Automação para Mineração de Bitcoin
# Copie este arquivo para .env e configure suas variáveis

# =============================================================================
# CONFIGURAÇÕES GERAIS
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
APP_NAME="Bitcoin Mining Automation"
APP_VERSION="1.0.0"

# =============================================================================
# BANCO DE DADOS
# =============================================================================
# PostgreSQL
DATABASE_URL=postgresql://bitcoin_mining:password@localhost:5432/bitcoin_mining

# Redis para cache
REDIS_URL=redis://localhost:6379

# =============================================================================
# MESSAGE QUEUE
# =============================================================================
# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# =============================================================================
# LLM (LARGE LANGUAGE MODEL)
# =============================================================================
# Modo: local ou remote
LLM_MODE=local

# Para modo local (Ollama)
LLM_ENDPOINT=http://localhost:11434

# Para modo remote
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# DISPOSITIVOS
# =============================================================================
# Inversor ABB
ABB_HOST=192.168.0.10
ABB_PORT=502
ABB_SLAVE_ID=1

# Sensores BLE
BLE_INTERFACE=/dev/ttyUSB0
BLE_BAUDRATE=9600

# ASICs
HASHCORE_PATH=/usr/local/bin/hashcore
ASIC_TIMEOUT=30
ASIC_RETRY_ATTEMPTS=3

# =============================================================================
# POOLS DE MINERAÇÃO
# =============================================================================
# F2Pool
F2POOL_API_TOKEN=your_f2pool_api_token_here
POOL_URL=https://api.f2pool.com

# Slush Pool (opcional)
SLUSH_POOL_TOKEN=your_slush_pool_token_here

# =============================================================================
# NOTIFICAÇÕES
# =============================================================================
# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_business_token_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# =============================================================================
# MONITORAMENTO
# =============================================================================
# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# CONFIGURAÇÕES DE COLETA DE DADOS
# =============================================================================
# Intervalo de coleta em segundos
COLLECTION_INTERVAL=1

# Tamanho da fila de dados
QUEUE_SIZE=1000

# =============================================================================
# CONFIGURAÇÕES DE ALERTAS
# =============================================================================
# Cooldown entre alertas em segundos
ALERT_COOLDOWN=300

# Máximo de alertas por hora
MAX_ALERTS_PER_HOUR=10

# =============================================================================
# THRESHOLDS (LIMIARES)
# =============================================================================
# Temperatura
TEMP_MAX=80.0
TEMP_CRITICAL=85.0

# Umidade
HUMIDITY_MAX=80.0
DEWPOINT_DIFF=2.0

# Eficiência
EFFICIENCY_MIN=0.8
HASHRATE_MIN=0.9

# =============================================================================
# CONFIGURAÇÕES DE REDE
# =============================================================================
# Timeout de conexão em segundos
CONNECTION_TIMEOUT=30

# Máximo de tentativas de reconexão
MAX_RETRIES=3

# =============================================================================
# CONFIGURAÇÕES DE BACKUP
# =============================================================================
# Intervalo de backup em segundos
BACKUP_INTERVAL=3600

# Dias para reter backups
BACKUP_RETENTION_DAYS=30

# =============================================================================
# CONFIGURAÇÕES DE SEGURANÇA
# =============================================================================
# Chave secreta para JWT
SECRET_KEY=your_secret_key_here

# Tempo de expiração do token em segundos
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# =============================================================================
# Apenas para desenvolvimento
RELOAD=false
HOST=0.0.0.0
PORT=8000

# =============================================================================
# CONFIGURAÇÕES DE LOG
# =============================================================================
# Arquivo de log
LOG_FILE=bitcoin_mining.log

# Nível de log
LOG_LEVEL=INFO

# =============================================================================
# CONFIGURAÇÕES DE PERFORMANCE
# =============================================================================
# Número máximo de workers
MAX_WORKERS=10

# Tamanho do lote para processamento
BATCH_SIZE=100

# TTL do cache em segundos
CACHE_TTL=300

# Tamanho do pool de conexões
CONNECTION_POOL_SIZE=20

# =============================================================================
# CONFIGURAÇÕES ESPECÍFICAS DO RASPBERRY PI
# =============================================================================
# GPIO para controle de ventiladores
FAN_GPIO_PIN=18

# GPIO para controle de refrigeração
COOLING_GPIO_PIN=19

# Configuração de swap
SWAP_SIZE=2G

# =============================================================================
# CONFIGURAÇÕES DE INTEGRAÇÃO
# =============================================================================
# API de preços de criptomoedas
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# API de preços de energia
ENERGY_API_KEY=your_energy_api_key_here

# Webhook para integrações externas
WEBHOOK_URL=your_webhook_url_here

# =============================================================================
# CONFIGURAÇÕES DE TESTE
# =============================================================================
# Modo de teste
TEST_MODE=false

# Dados simulados
SIMULATE_DATA=false

# Mock de dispositivos
MOCK_DEVICES=false


